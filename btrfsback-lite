#!/bin/bash
# BTRFS snapshot & replication script.
# set -xv

# ================================
# Dependencies check
# ================================
dep_exit=0
readonly DEPS=("date" "tree" "sendmail" "postfix" "awk" "btrfs" "ssh")
for dep in "${DEPS[@]}"; do
    if ! type -P "${dep}" &> /dev/null; then
        echo "Command not found: ${dep}"
        dep_exit=1
    fi
done

if [[ "${dep_exit}" -eq 1 ]]; then
    exit 1
fi

# ================================
# Help function
# ================================
print_help() {
    cat <<EOH
=================================================================================
BTRFS snapshot and replication script - btrfsback-lite
=================================================================================

Usage:
    -s, --subvol        Selected BTRFS subvolume for snapshot
    -l, --local-dir     Location of snapshots
    -d, --snap-local    Number of local daily snapshots to keep
    -H, --remote-host   Remote Host IP Address
    -r, --remote-dir    Remote location of snapshots
    -D, --snap-remote   Number of remote daily snapshots to keep
    -h, --help          This help message
EOH
}

# ================================
# Parse options
# ================================
OPTS="$(getopt -o s:l:H:r:d:D:h -l subvol:,local-dir:,remote-host:,remote-dir:,snap-local:,snap-remote:,help -- "$@")"
eval set -- "$OPTS"

while true; do
    case $1 in
        -s|--subvol) SUBVOL="$2"; shift 2;;
        -l|--local-dir) BACKUP_DIR_LOCAL="$2"; shift 2;;
        -d|--snap-local) SNAP_COUNT_LOCAL="$2"; shift 2;;
        -H|--remote-host) REMOTE_HOST="$2"; shift 2;;
        -r|--remote-dir) BACKUP_DIR_REMOTE="$2"; shift 2;;
        -D|--snap-remote) SNAP_COUNT_REMOTE="$2"; shift 2;;
        -h|--help) print_help; exit 0;;
        --) shift; break;;
        *) break;;
    esac
done

# ================================
# Basic validation
# ================================
for var in SUBVOL BACKUP_DIR_LOCAL SNAP_COUNT_LOCAL REMOTE_HOST BACKUP_DIR_REMOTE SNAP_COUNT_REMOTE; do
    if [[ -z "${!var}" ]]; then
        echo "Missing required parameter: $var"
        print_help
        exit 1
    fi
done

DATE_CURRENT=$(date +%Y-%m-%d_%H-%M-%S)
HOSTNAME=$(hostname)

# ================================
# Snapshot creation
# ================================
echo "========================================================================================"
echo " Backup Started: $(date '+%Y-%m-%d %H:%M:%S')"
echo " Subvol: $SUBVOL"
echo "========================================================================================"

sync
btrfs subvolume snapshot -r "$SUBVOL" "$BACKUP_DIR_LOCAL/$DATE_CURRENT"

# Delete older local snapshots
echo "Deleting older local snapshots..."
SNAPS_TO_DELETE=$(ls -1d "$BACKUP_DIR_LOCAL"/* 2>/dev/null | sort | head -n -"$SNAP_COUNT_LOCAL")
if [[ -n "$SNAPS_TO_DELETE" ]]; then
    echo "$SNAPS_TO_DELETE" | while read OLD; do
        [[ -d "$OLD" ]] && btrfs subvolume delete "$OLD" 2>/dev/null
    done
fi

# ================================
# Replication to remote
# ================================
echo "Replicating to remote host: $REMOTE_HOST"

# First sync detection
if ssh "$REMOTE_HOST" "[ -z \"\$(ls -A $BACKUP_DIR_REMOTE 2>/dev/null)\" ]"; then
    echo "First sync detected - remote backup directory is empty."
    btrfs send -q "$BACKUP_DIR_LOCAL/$DATE_CURRENT" | \
        ssh "$REMOTE_HOST" btrfs receive -q "$BACKUP_DIR_REMOTE"
else
    PREV_SNAP=$(ssh "$REMOTE_HOST" "ls -1 $BACKUP_DIR_REMOTE 2>/dev/null | sort | tail -n 1")
    if [[ -n "$PREV_SNAP" ]] && [[ -d "$BACKUP_DIR_LOCAL/$PREV_SNAP" ]]; then
        echo "Incremental send: $PREV_SNAP -> $DATE_CURRENT"
        btrfs send -q -p "$BACKUP_DIR_LOCAL/$PREV_SNAP" "$BACKUP_DIR_LOCAL/$DATE_CURRENT" | \
            ssh "$REMOTE_HOST" btrfs receive -q "$BACKUP_DIR_REMOTE"
    else
        echo "No common snapshot on remote, performing full send..."
        btrfs send -q "$BACKUP_DIR_LOCAL/$DATE_CURRENT" | \
            ssh "$REMOTE_HOST" btrfs receive -q "$BACKUP_DIR_REMOTE"
    fi
fi

# Delete older remote snapshots
echo "Deleting older remote snapshots..."
ssh "$REMOTE_HOST" "ls -1d $BACKUP_DIR_REMOTE/* 2>/dev/null | sort | head -n -$SNAP_COUNT_REMOTE | xargs -r -I {} btrfs subvolume delete {} 2>/dev/null"

# ================================
# End
# ================================
# List snapshots tree (no report) + accurate counts under it
echo "---------------------------------------------------------------------------------------"
echo " "
echo "Local snapshots:"
tree -d -L 1 --noreport "$BACKUP_DIR_LOCAL"
LOCAL_COUNT=$(ls -1 "$BACKUP_DIR_LOCAL" 2>/dev/null | wc -l)
echo "Local snapshot count: $LOCAL_COUNT / $SNAP_COUNT_LOCAL"

echo "---------------------------------------------------------------------------------------"
echo " "
echo "Remote snapshots:"
ssh "$REMOTE_HOST" "tree -d -L 1 --noreport \"$BACKUP_DIR_REMOTE\" 2>/dev/null || true"
REMOTE_COUNT=$(ssh "$REMOTE_HOST" "ls -1 \"$BACKUP_DIR_REMOTE\" 2>/dev/null | wc -l")
echo "Remote snapshot count: $REMOTE_COUNT / $SNAP_COUNT_REMOTE"
echo " "
echo "========================================================================================"
echo " Backup End: $(date '+%Y-%m-%d %H:%M:%S')"
echo "========================================================================================"
echo " "
echo " "
