#!/bin/bash

# Timestamp for the log file name
LOG_DATE=$(date +%Y-%m-%d_%H-%M-%S)
LOG_FILE="/var/log/btrlb_${LOG_DATE}.log"

# Save original stdout and stderr to prevent infinite loops during mail execution
exec 3>&1 4>&2
exec > >(tee -a "$LOG_FILE") 2>&1

# Check dependencies
readonly DEPS=("date" "tree" "mail" "postfix" "pv" "awk" "btrfs")

for dep in "${DEPS[@]}"; do
    if ! type -P "${dep}" &> /dev/null; then
        echo "Command not found: ${dep}"
        dep_exit=1
    fi
done

if [[ "${dep_exit}" -eq 1 ]]; then
    exec 1>&3 2>&4 3>&- 4>&-
    exit 1
fi

print_help() {
    /usr/bin/cat << EOH
==========================================================================================================
This is a lightweight BTRFS local only snapshot script in BASH. v1.4
==========================================================================================================
Usage:
    -s, --subvol        -Selected BTRFS subvolume for snapshot.
    -l, --local-dir     -Location of snapshots.
    -d, --daily-local   -Number of local daily snapshots to keep.
    -h, --help          -This help.
EOH
}

OPTS="$(getopt -o s:l:d:h -l subvol:,local-dir:,daily-local:,help -- "$@")"
eval set -- "$OPTS"

while true; do
    case $1 in
        -s|--subvol)
            SUBVOL="${2}"; shift 2;;
        -l|--local-dir)
            BACKUP_DIR_LOCAL="${2}"; shift 2;;
        -d|--daily-local)
            SNAP_COUNT_LOCAL="${2}"; shift 2;;
        -h|--help)
            print_help; exec 1>&3 2>&4 3>&- 4>&-; exit 0;;
        --)
            shift; break;;
        *)
            break;;
    esac
done

if [ -z "$SUBVOL" ] || [ -z "$BACKUP_DIR_LOCAL" ] || [ -z "$SNAP_COUNT_LOCAL" ]; then
    echo "Error: Missing required arguments."
    print_help
    exec 1>&3 2>&4 3>&- 4>&-
    exit 1
fi

DATE_CURRENT=$(date +%Y-%m-%d_%H-%M-%S)
HOSTNAME=$(hostname)
EMAIL="info@unixit.org"

echo "========================================================================="
echo " Backup Started..                                         $(date '+%Y-%m-%d %H:%M:%S')"
echo " Subvol: $SUBVOL"
echo "========================================================================="

sync

# Create new snapshot matching the target naming pattern
btrfs subvolume snapshot -r "$SUBVOL" "$BACKUP_DIR_LOCAL/$DATE_CURRENT"

echo "Checking for old snapshots to delete (Keep: $SNAP_COUNT_LOCAL)..."
# List and sort snapshots matching the precise naming pattern
CURRENT_SNAPS=$(ls -1d "$BACKUP_DIR_LOCAL"/[0-9]*-[0-9]*_[0-9]*-[0-9]*-[0-9]* 2>/dev/null | sort)
SNAP_COUNT=$(echo "$CURRENT_SNAPS" | grep -c '^')

if [ "$SNAP_COUNT" -gt "$SNAP_COUNT_LOCAL" ]; then
    DIFF=$((SNAP_COUNT - SNAP_COUNT_LOCAL))
    echo "$CURRENT_SNAPS" | head -n "$DIFF" | while read -r old_snap; do
        echo "Deleting old snapshot: $old_snap"
        btrfs subvolume delete "$old_snap"
    done
fi

echo " "
echo " - LOCAL Backups:"
tree -a -d -L 1 "$BACKUP_DIR_LOCAL" | awk '
  /directories/ {
    snaps = $1 - 1;
    print snaps " Snapshots"
    next
  }
  { print }
'
echo " "
echo "_______________________________________________________________________________________________________" 
echo " Backup End.                                              $(date '+%Y-%m-%d %H:%M:%S')"
echo " "

# Restore original stdout/stderr to stop tee before reading the log file
exec 1>&3 2>&4 3>&- 4>&-

